{
  "name": "movies-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:imgproxy:up && next dev",
    "dev:imgproxy:up": "docker compose -f docker-compose.dev.yml up -d",
    "dev:imgproxy:down": "docker compose -f docker-compose.dev.yml down",
    "build": "pnpm lint && next build",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "db": "drizzle-kit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@better-auth/passkey": "^1.6.11",
    "@imgproxy/imgproxy-js-core": "^1.8.0",
    "@imgproxy/imgproxy-node": "^1.1.0",
    "@neondatabase/serverless": "^1.1.0",
    "@primer/octicons-react": "^19.27.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "postcss": "8.5.15",
    "posthog-js": "^1.376.0",
    "posthog-node": "^5.35.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.100.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "shadcn": "^4.8.0",
