{
  "name": "movies",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "check-types": "nx run-many -t check-types",
    "dev:web": "nx run-many -t dev --projects=web",
    "db:push": "nx run-many -t db:push --projects=@movies/db",
    "db:studio": "nx run-many -t db:studio --projects=@movies/db",
    "db:generate": "nx run-many -t db:generate --projects=@movies/db",
    "db:migrate": "nx run-many -t db:migrate --projects=@movies/db",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@movies/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@movies/config": "workspace:*",
    "@types/node": "catalog:",
    "nx": "^21.5.2",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.31.0"
}
