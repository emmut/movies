{
  "name": "movies-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:docker:up && next dev",
    "dev:docker:up": "docker compose -f docker-compose.dev.yml up -d",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "build": "pnpm lint && next build",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium",
    "fallow": "fallow audit",
    "fallow:dead-code": "fallow dead-code",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "db": "drizzle-kit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx --env-file=.env scripts/seed-watchlist-and-lists.ts",
    "ingest:imdb": "tsx --env-file-if-exists=.env scripts/ingest-imdb-ratings.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@better-auth/passkey": "^1.6.23",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@imgproxy/imgproxy-js-core": "^1.8.0",
    "@imgproxy/imgproxy-node": "^1.1.0",
    "@primer/octicons-react": "^19.29.2",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^7.0.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "nuqs": "^2.9.0",
    "pg": "^8.22.0",
    "postcss": "8.5.16",
    "posthog-js": "^1.399.4",
    "posthog-node": "^5.41.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-better-tailwindcss": "^4.6.1",
    "fallow": "^2.104.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "railway": "^3.5.2",
    "shadcn": "^4.13.0",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "core-js",
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  }
}
