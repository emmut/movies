{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": [
    "next/core-web-vitals",
    "next/typescript"
  ],
  "plugins": [
    "nextjs",
    "react",
    "jsx-a11y",
    "typescript"
  ],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "jsPlugins": [
    "eslint-plugin-better-tailwindcss"
  ],
  "ignorePatterns": [
    ".next/**",
    "out/**",
    "build/**",
    "next-env.d.ts"
  ],
  "rules": {
    "better-tailwindcss/no-conflicting-classes": [
      "error",
      {
        "entryPoint": "./src/app/globals.css"
      }
    ]
  }
}
